/* Основные стили */
body {
    font-family: 'Arial', sans-serif;
    background: #f8f9fa;
    color: #333;
    margin: 0;
    padding: 20px;
}

.hidden {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    height: 0 !important;
    width: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
}

/* Форма */
.modern-form {
    background: #fff;
    border-radius: 10px;
    padding: 20px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    max-width: 600px;
    margin: auto;
}

/* Заголовки */
h2 {
    text-align: center;
    color: #007bff;
}

/* Группы полей */
.form-group {
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    font-weight: bold;
    margin-bottom: 5px;
}

.form-group-flex {
    display: flex;
    align-items: center;
    gap: 10px;
}

/* Поля ввода */
.form-input {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 16px;
}

/* Кнопки */
.btn-modern {
    padding: 10px 15px;
    border: none;
    background: #007bff;
    color: white;
    border-radius: 5px;
    cursor: pointer;
    transition: 0.3s;
}

.btn-modern:hover {
    background: #0056b3;
}

/* Модальные окна */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    justify-content: center;
    align-items: center;
}

.modal.open {
    display: flex;
}

.modal-content {
    background: #fff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    width: 90%;
    max-width: 400px;
}

/* Список внутри модалок */
.modal-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.modal-list li {
    padding: 10px;
    border-bottom: 1px solid #ddd;
    cursor: pointer;
}

.modal-list li:hover {
    background: #f1f1f1;
}

/* Уведомления */
#notification-container {
    position: fixed;
    top: 20px;
    right: 20px;
    width: auto;
    z-index: 1000;
}

.notification {
    background: #007bff;
    color: white;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 5px;
    opacity: 0;
    transform: translateY(-10px);
    transition: 0.3s;
}

.notification.show {
    opacity: 1;
    transform: translateY(0);
}

.notification.error {
    background-color: #dc3545;
    color: white;
}

/* Адаптация для мобильных устройств */
@media (max-width: 768px) {
    body {
        padding: 10px;
    }

    .modern-form {
        padding: 15px;
    }

    .form-group-flex {
        flex-direction: column;
        align-items: stretch;
    }

    .btn-modern {
        width: 100%;
    }

    .modal-content {
        width: 95%;
    }
    .x {
        width: 40px;
        height: 40px;
        font-size: 24px;
    }
}

/* Стили для чекбокса */
.form-checkbox {
    width: 20px;
    height: 20px;
    cursor: pointer;
}

.request-number {
    font-size: 28px;
    font-weight: bold;
    color: #007bff;
    display: block;
    text-align: center;
    margin-top: 10px;
    margin-bottom: 20px;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.05);
    }
    100% {
        transform: scale(1);
    }
}

/* Стили для просмотра прикрепленных фото */
.photo-container {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.photo-wrapper {
    position: relative;
}

.full-photo {
    max-width: 90%;
    max-height: 90vh;
    display: block;
    margin: 0 auto;
}

.photo-wrapper {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 10px;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.attached-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s;
}

.attached-photo.loading {
    opacity: 0.5;
    background: #f5f5f5;
}

.photo-wrapper.temporary {
    border: 2px dashed #4CAF50;
}

.delete-photo-btn {
    position: absolute;
    bottom: 5px;
    right: 5px;
    padding: 3px 8px;
    background: #dc3545;
    color: white;
    border: none;
    border-radius: 3px;
    font-size: 12px;
    cursor: pointer;
}

.delete-photo-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.error {
    color: #dc3545;
    padding: 10px;
    text-align: center;
}

.error-field {
    border: 2px solid #ff0000 !important;
    box-shadow: 0 0 5px rgba(255, 0, 0, 0.5) !important;
}

/* Закрытие модальных окон */
.modal-content {
    position: relative; /* Добавляем это для правильного позиционирования .x */
    padding: 40px 20px 20px; /* Увеличиваем верхний отступ для кнопки закрытия */
}

.selectable-multiple {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px;
    cursor: pointer;
}

.selectable-multiple:hover {
    background-color: #f0f0f0;
}

.multiple-confirm {
    text-align: right;
    margin-top: 15px;
}

.x {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 50%;
    font: 20px/1 Arial, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
    z-index: 10; /* Чтобы кнопка была поверх других элементов */
}

.x:hover {
    background: rgba(0, 0, 0, 0.05);
}

.x:active {
    background: rgba(0, 0, 0, 0.1);
}

.selectable.selected {
    background-color: #d0ebff;
    font-weight: bold;
}
